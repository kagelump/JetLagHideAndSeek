{
    "cli": {
        "version": ">= 13.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "simulator": false
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal",
                "releaseStatus": "completed"
            },
            "ios": {
                "appleTeamId": "442BWTA4F4",
                "ascAppId": "6776217435"
            }
        }
    }
}
