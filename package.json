{
    "name": "mobile_v2",
    "version": "0.1.4",
    "main": "expo-router/entry",
    "expo": {
        "autolinking": {
            "nativeModulesDir": "modules"
        }
    },
    "scripts": {
        "start": "expo start",
        "release": "node scripts/release.mjs",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "fix": "pnpm lint:fix && pnpm format",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm perf:typecheck && pnpm test:data:poi-selectors && pnpm check:circ",
        "check:circ": "node scripts/check-circular-deps.mjs",
        "perf:baseline": "node --import tsx perf/run.mts --json perf/baselines/reference.json && prettier perf/baselines/reference.json --write",
        "perf:capture": "node --import tsx perf/capture.mts && prettier perf/fixtures --write",
        "perf:compare": "node --import tsx perf/compare.mts",
        "perf:test": "node --import tsx perf/run.mts",
        "perf:typecheck": "tsc -p perf/tsconfig.json --noEmit",
        "data:default-zones": "node scripts/build-default-zone-metadata.mjs",
        "data:poi": "pnpm data:poi-selectors && node data/geofabrik/scripts/fetch-geofabrik.mjs --bundle",
        "data:poi-selectors": "node --import tsx scripts/emit-poi-selectors.mjs",
        "data:poi:packs": "pnpm data:poi-selectors && node data/geofabrik/scripts/fetch-geofabrik.mjs --cache-only --packs",
        "data:poi:packs:fetch": "pnpm data:poi-selectors && node data/geofabrik/scripts/fetch-geofabrik.mjs --packs",
        "data:geofabrik:bundle": "node data/geofabrik/scripts/fetch-geofabrik.mjs --cache-only --bundle",
        "data:geofabrik:packs": "node data/geofabrik/scripts/fetch-geofabrik.mjs --cache-only --packs",
        "data:geofabrik:packs:fetch": "node data/geofabrik/scripts/fetch-geofabrik.mjs --packs",
        "data:measuring": "node data/geofabrik/scripts/extract-measuring-bundles.mjs",
        "data:pack": "node --import tsx data/packs/scripts/build-packs.mjs",
        "data:pack:lint": "node data/packs/scripts/pack-lint.mjs",
        "data:pack:catalog": "node data/packs/scripts/build-catalog.mjs",
        "data:pack:publish": "node data/packs/scripts/publish.mjs",
        "data:transit": "node data/transit/scripts/extract-transit.mjs --locale japan",
        "geos:fetch": "bash modules/native-geometry/scripts/fetch-geos.sh",
        "geos:build:ios": "bash modules/native-geometry/scripts/build-geos-ios.sh",
        "geos:build:android": "bash modules/native-geometry/scripts/build-geos-android.sh",
        "site:build": "node scripts/build-share-site-config.mjs",
        "typecheck": "tsc --noEmit",
        "pretest": "node --test scripts/e2e-maestro-stack-config.test.mjs data/geofabrik/scripts/poiReducer.test.mjs data/transit/scripts/lib/*.test.mjs data/packs/scripts/lib/*.test.mjs tools/data-viewer/__tests__/*.test.mjs",
        "test": "jest",
        "test:geos": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.geos.js",
        "test:data:default-zones": "node scripts/build-default-zone-metadata.mjs --check",
        "test:data:transit": "node --test data/transit/scripts/lib/*.test.mjs",
        "test:data:poi-selectors": "node --import tsx scripts/emit-poi-selectors.mjs --check",
        "test:data:geofabrik": "node --test data/geofabrik/scripts/*.test.mjs",
        "test:data:packs": "node --test data/packs/scripts/lib/*.test.mjs",
        "test:e2e": "maestro test e2e/smoke.yaml",
        "test:e2e:stack": "node scripts/e2e-maestro-stack.mjs",
        "test:e2e:android": "pnpm test:e2e",
        "test:e2e:android:stack": "pnpm test:e2e:stack",
        "test:e2e:ios": "pnpm test:e2e",
        "test:e2e:ios:stack": "node scripts/e2e-ios-stack.mjs"
    },
    "dependencies": {
        "@gorhom/bottom-sheet": "^5.2.8",
        "@maplibre/maplibre-react-native": "^10.4.2",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@tanstack/query-async-storage-persister": "^5.100.14",
        "@tanstack/react-query": "^5.100.14",
        "@tanstack/react-query-persist-client": "^5.100.14",
        "@turf/boolean-point-in-polygon": "^7.3.5",
        "@turf/buffer": "^7.3.5",
        "@turf/center": "~7.3.5",
        "@turf/circle": "^7.2.0",
        "@turf/helpers": "^7.2.0",
        "@turf/line-split": "^7.3.5",
        "@turf/nearest-point-on-line": "^7.2.0",
        "@turf/simplify": "^7.3.5",
        "@turf/voronoi": "^7.3.5",
        "d3-geo": "~1.7.1",
        "expo": "~54.0.34",
        "expo-crypto": "~15.0.9",
        "expo-dev-client": "~6.0.21",
        "expo-file-system": "~19.0.23",
        "expo-location": "~19.0.8",
        "expo-router": "~6.0.23",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "fflate": "^0.8.2",
        "geokdbush": "^2.1.0",
        "kdbush": "^4.1.0",
        "osmtogeojson": "3.0.0-beta.5",
        "polyclip-ts": "^0.16.8",
        "qrcode": "^1.5.4",
        "react": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "~4.1.6",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.15.3",
        "semver": "^7.8.0",
        "zod": "^3.25.28"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@react-native-community/cli": "latest",
        "@testing-library/react-native": "^13.0.0",
        "@types/d3-geo": "^1.12.7",
        "@types/jest": "^29.5.0",
        "@types/react": "~19.1.10",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-rn-a11y": "^1.9.0",
        "geos-wasm": "^3.1.1",
        "globals": "^17.6.0",
        "jest-expo": "~54.0.0",
        "lint-staged": "^17.0.7",
        "prettier": "3.5.3",
        "react-test-renderer": "19.1.0",
        "simple-git-hooks": "^2.13.1",
        "tsx": "^4.22.4",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.59.3"
    },
    "private": true,
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged && pnpm typecheck"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
